# 🐺 ULUYI - Bozkırın Baskın Dili Yapılandırması

# Eski dosyaları ve veri setlerini 'dokümantasyon' olarak işaretle (Dil barında görünmezler)
01-biyotaklit-ve-etolojik-strateji/* linguist-documentation
02-dede-korkut-anlatilari/* linguist-documentation
03-tureyis-ve-ontoloji/* linguist-documentation
04-semiyoloji-ve-ikonografi/* linguist-documentation
data/* linguist-documentation
assets/* linguist-documentation

# Python motorlarını 'vendored' (dış kütüphane/araç) olarak işaretle
*.py linguist-vendored

# .uluy dosyalarını Wolfram Language olarak maskele (İsim benzerliği için)
*.uluy linguist-language=Wolfram
*.uluy linguist-detectable=true
